# ============================================================
# Aether Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Security — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here
SECRET_KEY=your_secret_key_32_chars_here

# Database
DATABASE_URL=postgresql+asyncpg://aether:aether_pass@localhost:5432/aether_db
# Fallback: DATABASE_URL=sqlite+aiosqlite:///./data/db/aether.db

# Redis (optional — in-memory fallback if not set)
REDIS_URL=redis://localhost:6379/0

# ChromaDB vector store path
CHROMA_PERSIST_DIR=./data/chroma

# ============================================================
# LLM Providers
# ============================================================
LLM_PRIMARY_PROVIDER=openai         # openai | anthropic
LLM_FALLBACK_PROVIDER=anthropic     # openai | anthropic
LLM_PRIMARY_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# Binance Exchange
# ============================================================
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true               # Set false for live trading

# ============================================================
# Polymarket
# ============================================================
POLYMARKET_PRIVATE_KEY=0x...        # Ethereum private key for Polygon
POLYMARKET_API_KEY=your_poly_api_key
POLYMARKET_API_SECRET=your_poly_api_secret
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137            # Polygon mainnet

# ============================================================
# On-Chain / Web3
# ============================================================
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_infura_key
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your_infura_key
ETHERSCAN_API_KEY=your_etherscan_api_key
MONITORED_WALLETS=0x...,0x...      # Comma-separated whale addresses

# ============================================================
# News / Research
# ============================================================
CRYPTOPANIC_API_KEY=your_cryptopanic_key
NEWS_API_KEY=your_newsapi_key

# ============================================================
# Notifications
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=your_alert_email@gmail.com

# ============================================================
# Brain Cycle Settings
# ============================================================
BRAIN_CYCLE_INTERVAL_SECONDS=300   # How often the brain runs (5 min default)
CONFIDENCE_THRESHOLD=0.65          # Min confidence to execute a trade
MAX_POSITION_SIZE_USD=1000         # Max single position size
DAILY_LOSS_LIMIT_USD=500           # Stop trading if daily loss exceeds this
ENABLE_LIVE_TRADING=false          # Master switch for real trades
